{
  "name": "obs-stream-overlay",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run update:emote-flags && run-p type-check \"build:only {@}\" --",
    "build:only": "npm run update:emote-flags && vite build",
    "dev": "npm run update:emote-flags && vite",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "npm run update:emote-flags && vite preview",
    "type-check": "vue-tsc --build --force",
    "update:emote-flags": "node scripts/update-emote-flags.cjs"
  },
  "dependencies": {
    "@atproto/api": "^0.19.3",
    "@splidejs/vue-splide": "^0.6.12",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.13.6",
    "lucide-vue-next": "^0.577.0",
    "obs-websocket-js": "^5.0.7",
    "pinia": "^3.0.4",
    "pinia-shared-state": "^1.0.1",
    "sass-migrator": "^2.5.7",
    "tmi-utils": "^1.0.1",
    "tmi.js": "^1.8.5",
    "vue": "^3.5.29",
    "vue-pdf-embed": "^2.1.4",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "@rushstack/eslint-patch": "^1.16.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^22.13.10",
    "@types/tmi.js": "^1.8.6",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "npm-run-all2": "^8.0.4",
    "sass": "^1.97.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vite-svg-loader": "^5.1.1",
    "vue-tsc": "^3.2.5"
  }
}
